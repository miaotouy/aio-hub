# =================================================================
# AIO Hub 开发环境配置模板
# 复制此文件为 .env.local 进行本地个性化配置
# =================================================================

# --- 端口配置 ---
# 前端 Vite 开发服务器端口 (默认: 1420)
AIO_PORT=1420
# Vite 热更新 (HMR) 端口 (默认: 1421)
AIO_HMR_PORT=1421
# Rust 后端 LLM 代理服务端口 (默认: 21655)
# 注意：Windows 上 Hyper-V/WinNAT 会动态保留大量端口（常落在 16xxx-17xxx 段），
# 触发 "os error 10013" 绑定失败。后端已支持自动 fallback，但建议选用 21000+ 安全段。
# 可用以下命令查看本机排除范围：netsh interface ipv4 show excludedportrange protocol=tcp
AIO_PROXY_PORT=21655

# --- 实例与隔离 ---
# 实例标识后缀 (用于多分支并行开发)
# 1. 若为空: 使用全局数据目录 (%APPDATA%)，适合日常开发
# 2. 若不为空 (如 dev-a):
#    - 应用标识变为 com.mty.aiohub.dev-a
#    - 数据目录隔离至 ./.dev-data/dev-a
#    - 端口会自动基于此后缀进行偏移，防止冲突
AIO_ID_SUFFIX=

# --- UI 展示 ---
# 产品名称前缀，方便在任务栏区分不同实例
AIO_PRODUCT_NAME=AIO Hub (Dev)

# --- VM 共享目录同步配置 (仅 Linux/VMware 环境有效) ---
# 若在 VMware 共享目录 (/mnt/hgfs/*) 下运行脚本，会自动同步代码到 VM 原生目录并切换执行
# AIO_VM_REPO=/home/mty/aio-hub-Ubuntu
# AIO_VM_BRANCH=codex/aio-hub-ubuntu