{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AIO Hub",
  "version": "0.6.6-beta.2",
  "identifier": "com.mty.aiohub",
  "build": {
    "beforeDevCommand": "bun run vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**", "$APPLOCALDATA/**", "$APPDATA/**"],
          "deny": []
        }
      }
    }
  },
  "plugins": {
    "window": {
      "all": true
    },
    "shell": {
      "all": false,
      "open": true
    },
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "deep-link": {
      "desktop": {
        "schemes": ["aiohub"]
      }
    },
    "updater": {
      "windows": {
        "installMode": "passive"
      },
      "endpoints": [
        "https://github.com/miaotouy/aio-hub/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMyQTExNzU3RkZBNEQ0MjkKUldRcDFLVC9WeGVod3RFTVBQWHJ0R3lhUmNJSlFHbnhocTRNTlhRdzVzMmdtSGk2RC9sWjZLbU4K"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "appimage", "deb"],
    "resources": {
      "../public/canvases": "canvases",
      "../public/skills": "skills"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["English", "SimpChinese"],
        "displayLanguageSelector": true
      }
    }
  }
}
